generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  name      String?       //temp store
  password  String?       //hashed password
  expiresAt DateTime
  createdAt DateTime @default(now())
}